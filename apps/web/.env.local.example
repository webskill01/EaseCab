# Base URL of the EaseCab API (no trailing slash). The client appends /api/v1.
# Local dev points at the Express API on port 4000.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Firebase client (phone OTP) — public by design, gated by domain
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# FCM web push (Step 23) — public client values from Firebase Console → Project settings.
# VAPID key = Cloud Messaging → Web Push certificates → key pair.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# DEV ONLY (optional) — set to true to skip the reCAPTCHA challenge for Firebase
# test phone numbers during local verification.
# ⚠️ SECURITY (Phase-6 review M1): this bypasses bot protection on phone OTP. It must
# NEVER be set in any deployed environment — verify it is absent from GitHub Actions
# secrets, staging/prod env, and Docker ARGs before every deploy. (It is only ever set
# in local, gitignored .env.local for `next dev`.)
NEXT_PUBLIC_FIREBASE_TEST_MODE=

# DEMO ONLY (optional) — set to true to skip the Razorpay hosted popup and return a
# deterministic success. Pair with RAZORPAY_STUB=true on the API (which skips signature
# verification) so the upgrade→credit flow completes without a live gateway. Never set
# in production — payments would be bypassable.
NEXT_PUBLIC_RAZORPAY_STUB=

# Support contact for the top-bar headset button. Prefers WhatsApp (digits incl.
# country code, e.g. 919876543210); falls back to the email if the number is unset.
NEXT_PUBLIC_SUPPORT_WHATSAPP=
NEXT_PUBLIC_SUPPORT_EMAIL=support@easecab.com
