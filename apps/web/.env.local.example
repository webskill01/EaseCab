# Base URL of the EaseCab API (no trailing slash). The client appends /api/v1.
# Local dev points at the Express API on port 4000.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Firebase client (phone OTP) — public by design, gated by domain
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# FCM web push (Step 23) — public client values from Firebase Console → Project settings.
# VAPID key = Cloud Messaging → Web Push certificates → key pair.
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# DEV ONLY (optional) — set to true to skip the reCAPTCHA challenge for Firebase
# test phone numbers during local verification. Leave UNSET in production.
NEXT_PUBLIC_FIREBASE_TEST_MODE=
