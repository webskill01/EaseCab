# @easecab/api environment contract. Copy to .env and fill in real values.
# Validated at startup by Zod — the process exits on anything missing/invalid
# (CLAUDE.md §3). Two consumers share this file:
#   - the cron worker (src/cron/worker.js) needs ONLY the base vars below
#   - the Express server (src/server.js) also needs the SERVER block

# --- Base (cron + server) ---
# Pooled connection via Supabase pgBouncer (:6543). Never run migrations on this.
DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true
# Direct connection (:5432) — migrations/seed only (prisma migrate/seed).
DIRECT_URL=postgresql://USER:PASS@HOST:5432/postgres
# Shared VPS Redis, bound to localhost. The cron stale watcher reads the bot heartbeat here.
REDIS_URL=redis://127.0.0.1:6379

# Bot-feed health (Phase 2.5). Optional — defaults shown.
# BOT_FEED_ENABLED=true
# STALE_AFTER_MIN=20
# ACTIVE_HOUR_START_IST=6
# ACTIVE_HOUR_END_IST=23

# --- Server only (Express / src/server.js) ---
NODE_ENV=production
PORT=4000
# User JWT secrets — generate >=32 chars each, keep distinct, never commit real values:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Admin JWT secrets (Step 24a) — generate >=32 chars each, and they MUST differ from
# the user JWT_* secrets above (separate token families, CLAUDE.md §6):
ADMIN_JWT_ACCESS_SECRET=
ADMIN_JWT_REFRESH_SECRET=
ADMIN_JWT_ACCESS_TTL=15m
ADMIN_JWT_REFRESH_TTL=8h
# Parent domain for admin auth cookies (security-review M2) — set to `.easecab.com`
# in production so admin.easecab.com receives the cookie and its Next middleware can
# route-gate on it. Leave UNSET in dev/local (host-only cookie works on localhost):
ADMIN_COOKIE_DOMAIN=
# CORS allow-list (csv). No wildcard in production (CLAUDE.md §6).
# LOCAL smoke-test: use the localhost origins instead so the web (3000) + admin (3001)
# can call the API with credentials. Swap back to the https domains for a real deploy.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Firebase Admin (verify-otp) — backend only
# Service-account credentials from Firebase console → Project settings → Service accounts.
# PRIVATE_KEY holds literal "\n"; the SDK restores real newlines at init.
# NEVER put real credentials here or commit them (CLAUDE.md §11).
FIREBASE_PROJECT_ID=easecab-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@easecab-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Razorpay (Step 11) — backend only, never in the frontend bundle (CLAUDE.md §11).
# Use Razorpay TEST-mode keys for dev/staging (no KYC/incorporation needed); swap to
# live keys at go-live (zero code change). KEY_ID is the public checkout key;
# KEY_SECRET signs the client /verify callback; WEBHOOK_SECRET signs the webhook body.
# Secrets must be >=16 chars.
# Until activation, run with the deterministic stub (no Razorpay account needed):
# RAZORPAY_STUB=true also skips client/webhook signature verification so the full
# upgrade→credit flow works in a demo. The KEY_ID/SECRET below still need dummy values
# (>=16 chars for the secrets) to satisfy startup validation. Never true in production.
RAZORPAY_STUB=true
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=stub_secret_min_16_chars_xxxxx
RAZORPAY_WEBHOOK_SECRET=stub_webhook_secret_min_16_chars_xxxxx

# Surepass KYC (Step 12) — BACKEND ONLY, never in the frontend bundle (CLAUDE.md §11).
# Until incorporation, run with the deterministic stub (no Surepass account needed):
SUREPASS_STUB=true
# At go-live, set SUREPASS_STUB=false and provide the real bearer token (>=16 chars):
SUREPASS_TOKEN=replace_with_surepass_bearer_token_min_16_chars
SUREPASS_BASE_URL=https://kyc-api.surepass.io

# Cloudflare R2 (Step 21a) — presigned image uploads. BACKEND ONLY (§11/§12).
# Set R2_STUB=true for local dev (no real bucket needed); never in production.
R2_STUB=true
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key_min_16_chars
R2_BUCKET=easecab-uploads
R2_PUBLIC_BASE_URL=https://cdn.easecab.com
