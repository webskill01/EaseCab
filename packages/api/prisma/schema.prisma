// EaseCab — Prisma schema (Build Order Step 2)
// JavaScript project: Prisma runs in JS mode; Zod (packages/shared) is the runtime
// type-safety layer. This schema is the single source of truth for the DB structure.
// All migrations are reversible. Never alter the DB directly.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL") // pooled (pgBouncer / transaction mode) — app runtime
  directUrl  = env("DIRECT_URL")   // direct (session mode) — migrations only
  extensions = [pg_trgm]           // fuzzy city-string matching (CityResolverService layer 3)
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum CityType {
  metro
  city
  town
  village
  landmark
}

enum AliasSource {
  migrated
  manual
  ai
  inferred
}

enum RideStatus {
  fresh
  booked
  hidden
}

// Which feed a recorded contact came from — persisted on RideContact so the
// "Contacted" list survives the source ride's hard-delete (Step 19 snapshot).
enum ContactSource {
  bot
  posted
}

enum PostedRideStatus {
  active
  done
  expired
  deleted
}

enum VerificationStatus {
  none
  submitted
  approved
  rejected
}

// aadhaar = national ID | dl = driving licence | rc = registration certificate
enum VerificationDocType {
  aadhaar
  dl
  rc
}

enum SubscriptionStatus {
  trial
  active
  expired
  halted
  cancelled
}

enum PaymentStatus {
  created
  captured
  failed
}

enum ReportReason {
  fake
  spam
  wrong_info
  inappropriate
  other
}

enum ReportAction {
  dismiss
  remove
}

enum MessageType {
  text
  image
}

enum PushPlatform {
  android
  web
  ios
}

enum AdminRole {
  super
  reviewer
}

// ---------------------------------------------------------------------------
// CITY RESOLUTION
// ---------------------------------------------------------------------------

model City {
  id            String   @id @default(uuid()) @db.Uuid
  canonicalName String   @map("canonical_name")
  // Localized display names for the feed (#10). Null → the UI falls back to the
  // canonical (English/Latin) name. en + hinglish always render canonicalName.
  namePa        String?  @map("name_pa")
  nameHi        String?  @map("name_hi")
  state         String
  district      String?
  type          CityType @default(city)
  lat           Decimal? @db.Decimal(9, 6)
  lng           Decimal? @db.Decimal(9, 6)
  population    Int?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  aliases          CityAlias[]
  unresolvedHints  UnresolvedCityString[]
  pickupRides      Ride[]        @relation("RidePickupCity")
  dropRides        Ride[]        @relation("RideDropCity")
  fromPostedRides  PostedRide[]  @relation("PostedRideFromCity")
  toPostedRides    PostedRide[]  @relation("PostedRideToCity")

  @@unique([canonicalName, state]) // natural key — idempotent seeding
  @@index([state])
  @@index([isActive])
  // Trigram index for fuzzy matching on canonical_name (pg_trgm)
  @@index([canonicalName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("cities")
}

model CityAlias {
  id         String      @id @default(uuid()) @db.Uuid
  cityId     String      @map("city_id") @db.Uuid
  aliasText  String      @map("alias_text")
  source     AliasSource @default(manual)
  confidence Decimal     @default(1.0) @db.Decimal(3, 2)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([aliasText, cityId])
  @@index([cityId])
  // Trigram index powers CityResolverService layer 3 (similarity >= 0.3 floor).
  // NOTE: the resolver currently wraps this column in lower(), so this index is
  // not yet hit by the planner — see DECISIONS.md (db-review 2026-05-31) for the
  // lowercase-storage migration to enable it before ~500 cities.
  @@index([aliasText(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("city_aliases")
}

model UnresolvedCityString {
  id              String    @id @default(uuid()) @db.Uuid
  rawText         String    @unique @map("raw_text")
  occurrenceCount Int       @default(1) @map("occurrence_count")
  suggestedCityId String?   @map("suggested_city_id") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  suggestedCity City? @relation(fields: [suggestedCityId], references: [id], onDelete: SetNull)

  @@index([reviewedAt])
  @@index([suggestedCityId])
  @@map("unresolved_city_strings")
}

// ---------------------------------------------------------------------------
// RIDES (bot-scraped) + FINGERPRINTS
// ---------------------------------------------------------------------------

model Ride {
  id              String     @id @default(uuid()) @db.Uuid
  rawText         String     @map("raw_text")                 // original WA message
  displayText     String     @map("display_text")             // phone masked with ████
  pickupCityId    String?    @map("pickup_city_id") @db.Uuid
  dropCityId      String?    @map("drop_city_id") @db.Uuid
  pickupRaw       String?    @map("pickup_raw")
  dropRaw         String?    @map("drop_raw")
  phoneNumber     String     @map("phone_number")             // never exposed without active sub
  vehicleType     String?    @map("vehicle_type")
  sourceGroupId   String?    @map("source_group_id")
  sourceGroupName String?    @map("source_group_name")
  botId           String?    @map("bot_id")
  fingerprint     String                                       // dedup key (lives with row until hard delete)
  status          RideStatus @default(fresh)
  receivedAt      DateTime   @default(now()) @map("received_at") @db.Timestamptz(6)
  expiresAt       DateTime   @map("expires_at") @db.Timestamptz(6)   // 30 min — feed removal
  dbDeleteAt      DateTime   @map("db_delete_at") @db.Timestamptz(6) // 12h — hard delete
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  pickupCity City? @relation("RidePickupCity", fields: [pickupCityId], references: [id], onDelete: SetNull)
  dropCity   City? @relation("RideDropCity", fields: [dropCityId], references: [id], onDelete: SetNull)
  contacts   RideContact[]
  reports    RideReport[]

  @@index([fingerprint])
  @@index([status])
  @@index([expiresAt])
  @@index([dbDeleteAt])
  @@index([createdAt])
  @@index([pickupCityId])
  @@index([dropCityId])
  @@map("rides")
}

// Dedup authority. Separate table, 48h TTL, survives ride-row hard deletion.
model RideFingerprint {
  id          String   @id @default(uuid()) @db.Uuid
  fingerprint String   @unique
  rideId      String?  @map("ride_id") @db.Uuid // loose ref; nulled if ride deleted, row persists
  firstSeenAt DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6) // 48h from first_seen_at
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("ride_fingerprints")
}

// ---------------------------------------------------------------------------
// POSTED RIDES (app-native, verified)
// ---------------------------------------------------------------------------

model PostedRide {
  id          String           @id @default(uuid()) @db.Uuid
  postedBy    String           @map("posted_by") @db.Uuid
  fromCityId  String?          @map("from_city_id") @db.Uuid
  toCityId    String?          @map("to_city_id") @db.Uuid
  fromCityRaw String?          @map("from_city_raw")
  toCityRaw   String?          @map("to_city_raw")
  vehicleType String?          @map("vehicle_type")
  fare        Decimal?         @db.Decimal(10, 2)
  rideDate    DateTime?        @map("ride_date") @db.Date
  rideTime    DateTime?        @map("ride_time") @db.Time(6)
  phone       String
  notes       String?
  status      PostedRideStatus @default(active)
  isClosed    Boolean          @default(false) @map("is_closed")
  expiresAt   DateTime         @map("expires_at") @db.Timestamptz(6) // 24h default
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  poster   User          @relation(fields: [postedBy], references: [id], onDelete: Cascade)
  fromCity City?         @relation("PostedRideFromCity", fields: [fromCityId], references: [id], onDelete: SetNull)
  toCity   City?         @relation("PostedRideToCity", fields: [toCityId], references: [id], onDelete: SetNull)
  contacts RideContact[]
  reports  RideReport[]
  chats    Chat[]

  @@index([postedBy])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([fromCityId])
  @@index([toCityId])
  @@map("posted_rides")
}

// ---------------------------------------------------------------------------
// USERS
// ---------------------------------------------------------------------------

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  phone              String             @unique
  name               String?
  profilePicUrl      String?            @map("profile_pic_url")
  baseCity           String?            @map("base_city")
  vehicleType        String?            @map("vehicle_type")
  languagesSpoken    String[]           @map("languages_spoken")
  aadhaarVerified    Boolean            @default(false) @map("aadhaar_verified")
  dlSubmitted        Boolean            @default(false) @map("dl_submitted")
  rcSubmitted        Boolean            @default(false) @map("rc_submitted")
  verificationStatus VerificationStatus @default(none) @map("verification_status")
  licenseUrl         String?            @map("license_url")
  rcUrl              String?            @map("rc_url")
  bio                String?            @map("bio")                       // L1 profile-completeness blurb (Step 21b)
  experience         Int?               @map("experience")                // years of driving experience (profile stat, Batch D)
  workingCity        String?            @map("working_city")              // operational city, distinct from base (Batch D)
  carMake            String?            @map("car_make")                  // from RC verify (Step 21b)
  carModel           String?            @map("car_model")
  carRegNo           String?            @map("car_reg_no")
  carFrontUrl        String?            @map("car_front_url")             // public-tier car image (Step 21b)
  carBackUrl         String?            @map("car_back_url")
  aadhaarLast4       String?            @map("aadhaar_last4")             // masked display only — full number never stored (§10)
  notificationCities String[]           @map("notification_cities") // City UUIDs the user opted into (Step 15 push targeting key)
  notifyBotRides     Boolean            @default(true) @map("notify_bot_rides")    // per-source push toggle: bot-feed rides
  notifyPostedRides  Boolean            @default(true) @map("notify_posted_rides") // per-source push toggle: app-posted verified rides
  lastKnownCity      String?            @map("last_known_city")
  isDeleted          Boolean            @default(false) @map("is_deleted")
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription      Subscription?
  payments          Payment[]
  verificationSubmissions VerificationSubmission[]
  postedRides       PostedRide[]
  contacts          RideContact[]
  reports           RideReport[]
  pushSubscriptions PushSubscription[]
  initiatedChats    Chat[]             @relation("ChatInitiator")
  postedChats       Chat[]             @relation("ChatPoster")
  sentMessages      ChatMessage[]
  blocksMade        UserBlock[]        @relation("BlocksMade")
  blocksReceived    UserBlock[]        @relation("BlocksReceived")

  @@index([isDeleted])
  @@index([createdAt])
  // Push targeting (Step 15) does notification_cities && ARRAY[rideCityIds] on every
  // new-ride event — B-tree can't serve array-overlap, so GIN is required. Plain
  // CREATE INDEX here (MVP table is tiny, near-zero lock); switch to CONCURRENTLY in
  // a standalone migration if this is ever re-created on a large live table.
  @@index([notificationCities], type: Gin)
  @@map("users")
}

// ---------------------------------------------------------------------------
// SUBSCRIPTIONS
// ---------------------------------------------------------------------------

model Subscription {
  id             String             @id @default(uuid()) @db.Uuid
  userId         String             @unique @map("user_id") @db.Uuid
  status         SubscriptionStatus @default(trial)
  trialStartedAt DateTime           @default(now()) @map("trial_started_at") @db.Timestamptz(6)
  trialExpiresAt DateTime           @map("trial_expires_at") @db.Timestamptz(6) // +7d
  paidStartedAt  DateTime?          @map("paid_started_at") @db.Timestamptz(6)
  expiresAt      DateTime?          @map("expires_at") @db.Timestamptz(6) // null in trial; stacks on renewal
  razorpaySubId  String?            @map("razorpay_sub_id")
  razorpayPlanId String?            @map("razorpay_plan_id")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([expiresAt])
  @@index([trialExpiresAt])
  @@map("subscriptions")
}

// ---------------------------------------------------------------------------
// PAYMENTS (Razorpay one-time order ledger + webhook idempotency key)
// ---------------------------------------------------------------------------

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  // One row per Razorpay order — UNIQUE guards the create-order idempotency path
  // (db-review C2). The @unique auto-creates the lookup index.
  razorpayOrderId   String        @unique @map("razorpay_order_id")
  // Set when the payment is captured; UNIQUE is the hard capture-idempotency guarantee.
  // Nullable so a freshly-created (unpaid) order row can exist — Postgres allows
  // many NULLs under a UNIQUE constraint.
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  amount            Int // paise — multiply rupees by 100 before inserting; ₹149 = 14900
  status            PaymentStatus @default(created)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Restrict (db-review H2): retain the financial audit trail — the hard-delete
  // cron must archive/anonymize payments before a user row can be removed.
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Open-order lookup = newest `created` row for a user.
  @@index([userId, status])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// VERIFICATION SUBMISSIONS (Surepass KYC audit trail — Step 12)
// ---------------------------------------------------------------------------

model VerificationSubmission {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  docType      VerificationDocType @map("doc_type")
  // Step 12 only ever writes `submitted`; the Step-24 admin flow moves it to
  // approved/rejected (review columns added by that step's forward migration).
  status       VerificationStatus  @default(submitted)
  // Surepass client/transaction id for audit + dispute. The raw Aadhaar/DL/RC
  // NUMBER is never stored (CLAUDE.md §10 PII) — only the vendor reference + the
  // verified holder name for the admin to match against.
  surepassRef  String?             @map("surepass_ref")
  verifiedName String?             @map("verified_name")
  // Admin review audit (Step 24b). Step 12 writes null; the admin queue stamps these
  // on approve/reject. reviewedBy → admin_users.id (never users — §6).
  reviewedBy      String?          @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason String?          @map("rejection_reason")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Cascade (db-review GATE, user sign-off 2026-06-02): KYC PII should not outlive
  // the user — the 30-day hard-delete cron purges submissions with the user. Differs
  // from payments' Restrict (no financial/GST retention duty on KYC). The service
  // never calls user.delete() directly — only the soft-delete path (db-review H2).
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SetNull (Step 24b): retain the audit row if the reviewing admin is later removed.
  reviewer AdminUser? @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, createdAt]) // admin verifications queue: (status, newest-first)
  @@index([docType])
  @@index([reviewedBy]) // FK index (§7) — admin's reviewed-submissions lookup
  // NOTE: a partial-unique index UNIQUE(user_id, doc_type) WHERE status='submitted'
  // and a CHECK(status <> 'none') are added in the migration SQL — Prisma cannot
  // express WHERE-filtered indexes or CHECK constraints (db-review H3 + M2).
  @@map("verification_submissions")
}

// ---------------------------------------------------------------------------
// RIDE CONTACTS (history / "Contacted Rides")
// ---------------------------------------------------------------------------

model RideContact {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  rideId       String?  @map("ride_id") @db.Uuid          // bot ride (SetNull on hard-delete)
  postedRideId String?  @map("posted_ride_id") @db.Uuid   // verified ride (SetNull on hard-delete)
  contactedAt  DateTime @default(now()) @map("contacted_at") @db.Timestamptz(6)

  // Snapshot captured at reveal time so the "Contacted" list survives the source
  // ride's 12h hard-delete (Step 19). `source` distinguishes which feed it came from
  // once rideId/postedRideId are nulled by SetNull. Nullable: pre-Step-19 rows have none.
  source        ContactSource? @map("source")
  fromCityName  String?        @map("from_city_name")
  toCityName    String?        @map("to_city_name")
  vehicleType   String?        @map("vehicle_type")
  revealedPhone String?        @map("revealed_phone")
  // Poster identity snapshot (T3-3 Slice 2) so the Contacted card can show + link to
  // the verified poster's profile. Plain columns (no FK) — like the other snapshot
  // fields, they must outlive the source ride's hard-delete; navigation hits /u/[id].
  posterId      String?        @map("poster_id") @db.Uuid
  posterName    String?        @map("poster_name")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ride       Ride?       @relation(fields: [rideId], references: [id], onDelete: SetNull)
  postedRide PostedRide? @relation(fields: [postedRideId], references: [id], onDelete: SetNull)

  @@unique([userId, rideId])
  @@unique([userId, postedRideId])
  @@index([userId])
  @@index([userId, contactedAt])
  @@index([rideId])
  @@index([postedRideId])
  @@map("ride_contacts")
}

// ---------------------------------------------------------------------------
// RIDE REPORTS
// ---------------------------------------------------------------------------

model RideReport {
  id           String       @id @default(uuid()) @db.Uuid
  reporterId   String       @map("reporter_id") @db.Uuid
  rideId       String?      @map("ride_id") @db.Uuid
  postedRideId String?      @map("posted_ride_id") @db.Uuid
  reason       ReportReason
  remarks      String?
  screenshotUrl String?     @map("screenshot_url")
  reviewedAt   DateTime?    @map("reviewed_at") @db.Timestamptz(6)
  // Admin moderation verdict (Step 24c). reviewedBy → admin_users.id (never users — §6).
  reviewedBy    String?       @map("reviewed_by") @db.Uuid
  reviewAction  ReportAction? @map("review_action")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  reporter   User        @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  ride       Ride?       @relation(fields: [rideId], references: [id], onDelete: Cascade)
  postedRide PostedRide? @relation(fields: [postedRideId], references: [id], onDelete: Cascade)
  reviewer   AdminUser?  @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([rideId])
  @@index([postedRideId])
  @@index([reviewedAt])
  @@index([reviewedBy])
  @@index([createdAt])
  @@map("ride_reports")
}

// ---------------------------------------------------------------------------
// CHAT (Postgres mirror of Firestore threads)
// ---------------------------------------------------------------------------

model Chat {
  id            String   @id @default(uuid()) @db.Uuid
  postedRideId  String   @map("posted_ride_id") @db.Uuid
  initiatorId   String   @map("initiator_id") @db.Uuid
  posterId      String   @map("poster_id") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active") // false = read-only (ride expired/done)
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  postedRide PostedRide    @relation(fields: [postedRideId], references: [id], onDelete: Cascade)
  initiator  User          @relation("ChatInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  poster     User          @relation("ChatPoster", fields: [posterId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@unique([postedRideId, initiatorId])
  @@index([postedRideId])
  @@index([initiatorId])
  @@index([posterId])
  @@index([isActive])
  @@index([lastMessageAt])
  @@map("chats")
}

model ChatMessage {
  id            String      @id @default(uuid()) @db.Uuid
  chatId        String      @map("chat_id") @db.Uuid
  senderId      String      @map("sender_id") @db.Uuid
  messageType   MessageType @default(text) @map("message_type")
  messageText   String?     @map("message_text")    // null if image
  attachmentUrl String?     @map("attachment_url")  // null if text
  readAt        DateTime?   @map("read_at") @db.Timestamptz(6)
  sentAt        DateTime    @default(now()) @map("sent_at") @db.Timestamptz(6)

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([sentAt])
  @@map("chat_messages")
}

// User-to-user block (P12-4c). A block hides chat BOTH ways (enforced in chat
// open/send). blocker = the user who blocked; blocked = the target. The unique pair
// makes blocking idempotent. Feed/contact filtering is intentionally NOT enforced
// here (chat-only scope — see DECISIONS/PROGRESS).
model UserBlock {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  // No standalone @@index([blockerId]) — the unique (blocker_id, blocked_id) index
  // already serves blocker_id lookups + the FK cascade via its leading column.
  // blocked_id needs its own index (reverse-direction cascade, not a composite prefix).
  @@index([blockedId])
  @@map("user_blocks")
}

// ---------------------------------------------------------------------------
// PUSH SUBSCRIPTIONS (device tokens)
// ---------------------------------------------------------------------------

model PushSubscription {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  deviceToken String       @map("device_token") // FCM token OR Web Push subscription JSON
  platform    PushPlatform
  lastSeenAt  DateTime     @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([userId])
  @@map("push_subscriptions")
}

// ---------------------------------------------------------------------------
// ADMIN USERS (isolated from app users)
// ---------------------------------------------------------------------------

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  name         String?
  passwordHash String    @map("password_hash")
  role         AdminRole @default(reviewer)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  reviewedSubmissions VerificationSubmission[]
  reviewedReports     RideReport[]

  @@map("admin_users")
}
