# @easecab/bot — read-only WhatsApp listener (Baileys). Copy to .env (gitignored).
# Loaded automatically by `npm start` / `npm run pair` (--env-file-if-exists=.env).
# Validated at startup via config/env.schema.js — the process exits on a bad value.

# Pooled Postgres (pgBouncer :6543) — SAME database as the API. The bot never migrates.
DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true

# Redis — SAME instance as the API/cron (keys namespaced under easecab:).
REDIS_URL=redis://127.0.0.1:6379

# The WhatsApp GROUP whose messages the bot ingests, as a JID like `<digits>@g.us`.
# Get it after pairing: run `npm run pair`, then the pair script / logs print the JIDs
# of the groups the paired number is in — copy the target group's JID here.
WA_TARGET_GROUP_JID=

# Baileys auth-state root dir; each slot gets a <path>/<slot> subdir. Created by pairing.
WA_SESSION_PATH=./.wa-session

# Number-pool slot labels (opaque, NOT phone numbers — no PII), priority order.
# Start with one slot; add backups later by pairing more session dirs (e.g. slot-1,slot-2).
WA_NUMBERS=slot-1

# Kill switch (Phase 2.5). false → the bot connects but does not ingest anything.
BOT_FEED_ENABLED=true
